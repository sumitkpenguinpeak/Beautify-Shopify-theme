          "settings": {
            "icon": "none",
            "heading": "Does my piece come in any packaging?",
            "content": "<p>Yes, all our skincare products come in protective and aesthetically pleasing packaging to ensure they arrive in perfect condition. Each product is securely wrapped, and we use eco-friendly materials whenever possible. Additionally, many of our products come in recyclable containers to support sustainability.</p>",
            "custom_liquid": "",
            "page": "",
            "open": false
          }
        },
