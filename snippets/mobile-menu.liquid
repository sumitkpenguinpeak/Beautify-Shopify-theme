<div
  class="sleek-mobile-menu"
  data-mobile-menu
>
  <div
    class="sleek-mobile-menu__overlay"
    data-mobile-menu-close
  ></div>

  <div class="sleek-mobile-menu__drawer">

    <div class="sleek-mobile-menu__header">
      <span class="sleek-mobile-menu__title">
        Menu
      </span>

      <button
        type="button"
        class="sleek-mobile-menu__close"
        data-mobile-menu-close
        aria-label="Close menu"
      >
        &times;
      </button>
    </div>

    <nav class="sleek-mobile-menu__nav">
      {% for link in menu.links %}

        {% if link.links != blank %}

          <details class="sleek-mobile-menu__item">

            <summary>
              <span>{{ link.title }}</span>

              <svg
                width="12"
                height="7"
                viewBox="0 0 12 7"
                fill="none"
              >
                <path
                  d="M1 1L6 6L11 1"
                  stroke="currentColor"
                  stroke-width="1.3"
                />
              </svg>
            </summary>

            <div class="sleek-mobile-menu__submenu">

              {% for childlink in link.links %}

                {% if childlink.links != blank %}

                  <details class="sleek-mobile-menu__child">

                    <summary>
                      {{ childlink.title }}
                    </summary>

                    <div class="sleek-mobile-menu__grandchild">
                      {% for grandchildlink in childlink.links %}
                        <a href="{{ grandchildlink.url }}">
                          {{ grandchildlink.title }}
                        </a>
                      {% endfor %}
                    </div>

                  </details>

                {% else %}

                  <a href="{{ childlink.url }}">
                    {{ childlink.title }}
                  </a>

                {% endif %}

              {% endfor %}

            </div>

          </details>

        {% else %}

          <a
            href="{{ link.url }}"
            class="sleek-mobile-menu__single-link"
          >
            {{ link.title }}
          </a>

        {% endif %}

      {% endfor %}
    </nav>

    {% if shop.customer_accounts_enabled %}
      <div class="sleek-mobile-menu__footer">
        <a href="{{ routes.account_url }}">
          Account
        </a>
      </div>
    {% endif %}

  </div>
</div>