{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}

{% liquid
  assign blog = blogs[section.settings.blog]
  assign post_limit = section.settings.post_limit
  if blog != blank and blog.articles_count < post_limit
    assign post_limit = blog.articles_count
  endif

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign enable_swipe_mobile = false
  if section.settings.swipe_on_mobile and post_limit > columns_mobile_int
    assign enable_swipe_mobile = true
  endif

  assign columns_desktop = section.settings.columns_desktop
  assign columns_tablet = columns_desktop
  if columns_desktop > 3
    assign columns_tablet = columns_desktop | divided_by: 2.0 | ceil
  endif

  assign show_date = section.settings.show_date
  assign show_excerpt = section.settings.show_excerpt
  assign show_button = section.settings.show_button

  assign section_header_alignment = settings.section_header_alignment
  assign section_header_alignment_mobile = settings.section_header_alignment_mobile
  if section_header_alignment_mobile == 'inherit'
    assign section_header_alignment_mobile = section_header_alignment
  endif

  assign item_css_class = 'f-column'

  assign enable_slider = false
  if section.settings.enable_slider and post_limit > columns_desktop
    assign enable_slider = true
    assign item_css_class = item_css_class | append: ' swiper-slide'
  endif
%}

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}

<div
  class="section section-{{ section.id }} section--padding featured-blog color-{{ section.settings.color_scheme }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="--section-padding-top: {{ section.settings.padding_top }}px;--section-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {% render 'section-heading', section_settings: section.settings %}
    <grid-list class="block relative swiper-show-nav-on-hover">
      <featured-blog
        class="block{% if enable_slider %} swiper f-grid--gap-{{ section.settings.column_gap }}{% endif %}{% if enable_swipe_mobile %} swipe-mobile swipe-mobile--{{ columns_mobile_int }}-cols{% endif %}"
        data-section-id="{{ section.id }}"
        {% if enable_slider %}
          data-enable-slider="true"
          data-items="{{ columns_desktop }}"
          data-tablet-items="{{ columns_tablet }}"
          data-calc-button-position="true"
        {% endif %}
      >
        <div class="featured-blog__items f-grid f-grid-{{ columns_mobile_int }}-cols md:f-grid-{{ columns_tablet }}-cols lg:f-grid-{{ columns_desktop }}-cols f-grid--gap-{{ section.settings.column_gap }} f-grid--row-gap-{{ section.settings.column_gap }}{% if enable_slider %} swiper-wrapper{% endif %}{% if enable_swipe_mobile %} swipe-mobile__inner{% endif %}">
          {%- if section.settings.blog != blank and section.settings.blog.articles_count > 0 -%}
            {%- for article in blog.articles limit: post_limit -%}
              <div class="{{ item_css_class }}">
                {%- render 'card-article',
                  article: article,
                  show_date: show_date,
                  show_excerpt: show_excerpt,
                  show_button: show_button,
                  index: forloop.index,
                  title_size: section.settings.card_title_size
                -%}
              </div>
            {%- endfor -%}
          {% else %}
            {% for i in (1..post_limit) -%}
              <div class="{{ item_css_class }}">
                {%- render 'card-article-placeholder',
                  show_date: show_date,
                  show_excerpt: show_excerpt,
                  show_button: show_button,
                  title_size: section.settings.card_title_size,
                  index: forloop.index0
                -%}
              </div>
            {%- endfor -%}
          {% endif %}
        </div>
      </featured-blog>
      {%- if enable_slider -%}
        <div class="swiper-controls swiper-controls--{{ section.settings.controls_position }} hidden md:block">
          <button
            class="swiper-button-prev btn"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            {% render 'icon-slider-prev' %}
          </button>
          <button
            class="swiper-button-next btn"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            {% render 'icon-slider-next' %}
          </button>
        </div>
      {%- endif -%}
    </grid-list>
  </div>
</div>
<script src="{{ 'featured-blog.js' | asset_url }}" defer="defer"></script>
